<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Solrepo" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/sol_gold</item>
        <item name="colorPrimaryDark">@color/sol_gold_dark</item>
        <item name="colorAccent">@color/sol_gold</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/sol_background</item>
    </style>

    <style name="Theme.Solrepo" parent="Base.Theme.Solrepo" />

    <!-- Forces dark spinner text on the airport-transfer TimePicker. Without this some
         OEM themes resolve textColorPrimary to white, making the spinner invisible on the
         white card (renders as a blank white box). -->
    <style name="SpinnerTimePicker" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:textColorPrimary">@color/sol_text_primary</item>
        <item name="android:textColorSecondary">@color/sol_text_secondary</item>
        <item name="colorControlNormal">@color/sol_gold_dark</item>
        <item name="android:colorControlNormal">@color/sol_gold_dark</item>
        <item name="colorAccent">@color/sol_gold_dark</item>
        <item name="android:colorAccent">@color/sol_gold_dark</item>
    </style>

    <style name="AllServiceItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/bg_quick_access</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="AllServiceLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:gravity">center</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:background">@drawable/bg_chip_unselected</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="ServiceTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/bg_service_tile</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ServiceTileIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:tint">@color/sol_gold_dark</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="ServiceTileLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:gravity">center</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DiningSelCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="DiningSelLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/sol_text_secondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="DiningSelValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Spa booking summary grid cell -->
    <style name="SpaFactCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SpaFactIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:tint">@color/sol_gold_dark</item>
    </style>

    <style name="SpaFactLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textColor">@color/sol_text_secondary</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SpaFactValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Spa session-card info chip (price / specialists / sessions) -->
    <style name="SpaInfoChip">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/bg_spa_session_available</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="SpaInfoChipIcon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:tint">@color/sol_gold_dark</item>
    </style>

    <style name="SpaInfoChipText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Spa confirmation detail row -->
    <style name="SpaDetailRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="SpaDetailIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:tint">@color/sol_gold_dark</item>
    </style>

    <style name="SpaDetailLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/sol_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SpaDetailValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/sol_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SpaDetailDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/sol_border</item>
    </style>
</resources>
