<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dashboard_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_icon_soft"
        android:padding="16dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/account_my_bookings"
            android:src="@drawable/ic_stay" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtEmptyBookingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/account_no_current_message"
            android:textColor="@color/sol_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnCreateBooking"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_outline_button"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:minWidth="140dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/account_create_booking"
            android:textColor="@color/sol_gold_dark"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
