<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <androidx.cardview.widget.CardView
        android:layout_width="70dp"
        android:layout_height="70dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgCartItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/bg_menu_warm" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtCartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Truffle Mushroom Pasta" />

        <TextView
            android:id="@+id/txtCartItemDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter"
            android:maxLines="2"
            android:textColor="@color/sol_text_secondary"
            android:textSize="11sp"
            tools:text="Creamy truffle sauce, wild mushrooms" />

        <TextView
            android:id="@+id/txtCartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter"
            android:textColor="@color/sol_gold_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="$24.00" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="end"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_stepper"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCartMinus"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:contentDescription="@string/rs_decrease"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/sol_gold_dark"
                android:textSize="17sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/txtCartQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:minWidth="18dp"
                android:textColor="@color/sol_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="1" />

            <TextView
                android:id="@+id/btnCartPlus"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:contentDescription="@string/rs_increase"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/sol_gold_dark"
                android:textSize="17sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtCartLineTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"
            android:textColor="@color/sol_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="$24.00" />
    </LinearLayout>
</LinearLayout>
