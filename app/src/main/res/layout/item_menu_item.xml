<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_dashboard_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:layout_width="78dp"
        android:layout_height="78dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgMenuItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/bg_menu_warm" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtMenuName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Truffle Mushroom Pasta" />

        <TextView
            android:id="@+id/txtMenuDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter"
            android:maxLines="2"
            android:textColor="@color/sol_text_secondary"
            android:textSize="12sp"
            tools:text="Creamy truffle sauce, wild mushrooms, parmesan, fresh herbs" />

        <TextView
            android:id="@+id/txtMenuPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_gold_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="$24.00" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/btnMenuAdd"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_stepper"
        android:contentDescription="@string/rs_add_item">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="+"
            android:textColor="@color/sol_gold_dark"
            android:textSize="20sp"
            tools:ignore="HardcodedText" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/stepperMenu"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_stepper"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnMenuMinus"
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:contentDescription="@string/rs_decrease"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:text="−"
            android:textColor="@color/sol_gold_dark"
            android:textSize="18sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/txtMenuQty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:minWidth="20dp"
            android:gravity="center"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="1" />

        <TextView
            android:id="@+id/btnMenuPlus"
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:contentDescription="@string/rs_increase"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/sol_gold_dark"
            android:textSize="18sp"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</LinearLayout>
