<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    android:fillViewport="true"
    tools:context=".activities.TransferConfirmActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/btnTransferConfirmBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:contentDescription="@string/signup_back">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrowleft"
                    app:tint="@color/sol_gold_dark" />
            </FrameLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_icon_soft_circle">

            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_check"
                app:tint="@color/sol_gold" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtTransferConfirmTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:textColor="@color/sol_text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            tools:text="Pickup Confirmed" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/transfer_confirmed_sub"
            android:textColor="@color/sol_text_secondary"
            android:textSize="14sp" />

        <!-- Details card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_dashboard_card"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_gift" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_booking_id" />

                <TextView
                    android:id="@+id/txtTransferConfirmId"
                    style="@style/SpaDetailValue"
                    tools:text="PKUP-2026-1001" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_transfer" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_type_field" />

                <TextView
                    android:id="@+id/txtTransferConfirmType"
                    style="@style/SpaDetailValue"
                    tools:text="Pickup" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_home" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_from" />

                <TextView
                    android:id="@+id/txtTransferConfirmFrom"
                    style="@style/SpaDetailValue"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    tools:text="Da Nang International Airport (DAD)" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_home" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_to" />

                <TextView
                    android:id="@+id/txtTransferConfirmTo"
                    style="@style/SpaDetailValue"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    tools:text="Sol An Bang Beach Resort" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_calendar" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_datetime" />

                <TextView
                    android:id="@+id/txtTransferConfirmDateTime"
                    style="@style/SpaDetailValue"
                    tools:text="15 Oct 2026 • 03:00 PM" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_transfer" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_confirm_flight" />

                <TextView
                    android:id="@+id/txtTransferConfirmFlight"
                    style="@style/SpaDetailValue"
                    tools:text="VN123" />
            </LinearLayout>

            <View style="@style/SpaDetailDivider" />

            <LinearLayout style="@style/SpaDetailRow">

                <ImageView
                    style="@style/SpaDetailIcon"
                    android:src="@drawable/ic_profile" />

                <TextView
                    style="@style/SpaDetailLabel"
                    android:text="@string/transfer_guests" />

                <TextView
                    android:id="@+id/txtTransferConfirmGuests"
                    style="@style/SpaDetailValue"
                    tools:text="2 Guests" />
            </LinearLayout>
        </LinearLayout>

        <!-- Driver pending -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_amenity_item"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_clock"
                app:tint="@color/sol_gold_dark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/transfer_driver_pending_title"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter"
                    android:text="@string/transfer_driver_pending_desc"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btnTransferBackHome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_outline_button"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:text="@string/store_back_home"
            android:textColor="@color/sol_gold_dark"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
