<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp"
    tools:context=".activities.MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/dashboard_title"
        android:textColor="@color/sol_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_dashboard_card"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/txtWelcomeCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sol_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Welcome, Mai Nguyen" />

        <TextView
            android:id="@+id/txtAccountSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/sol_text_secondary"
            android:textSize="15sp"
            tools:text="Account: mai.nguyen@example.com&#10;Status: in_stay" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/dashboard_intro"
            android:textColor="@color/sol_text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnSignOut"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_gold_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/sign_out"
        android:textColor="@color/white"
        android:textSize="16sp" />

</LinearLayout>
