<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    tools:context=".activities.LoginActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideHeroBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <View
        android:id="@+id/heroBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_login"
        app:layout_constraintBottom_toTopOf="@id/guideHeroBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/brandBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/guideHeroBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="380dp"
        app:layout_constraintWidth_percent="0.78">

    </LinearLayout>

    <FrameLayout
        android:id="@+id/logoBadge"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:background="@drawable/bg_logo_circle"
        android:elevation="6dp"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/guideHeroBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideHeroBottom">

        <ImageView
            android:id="@+id/imgSolLogo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/logo_content_description"
            android:scaleType="fitCenter"
            android:src="@drawable/sol_logo"
            app:tint="@color/sol_gold_dark" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoBadge"
        app:layout_constraintWidth_max="420dp"
        app:layout_constraintWidth_percent="0.84">

        <TextView
            android:id="@+id/txtLoginTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:text="@string/login_title"
            android:textColor="@color/sol_text_primary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLoginSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/login_subtitle"
            android:textColor="@color/sol_text_secondary"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/emailBox"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:contentDescription="@string/email_hint"
                android:src="@drawable/ic_mail" />

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:autofillHints="emailAddress"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans"
                android:hint="@string/email_hint"
                android:inputType="textEmailAddress"
                android:paddingStart="58dp"
                android:paddingEnd="20dp"
                android:singleLine="true"
                android:textColor="@color/sol_text_primary"
                android:textColorHint="@color/sol_text_secondary"
                android:textSize="15sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/passwordBox"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:contentDescription="@string/password_hint"
                android:src="@drawable/ic_lock" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:autofillHints="password"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans"
                android:hint="@string/password_hint"
                android:inputType="textPassword"
                android:paddingStart="58dp"
                android:paddingEnd="76dp"
                android:singleLine="true"
                android:textColor="@color/sol_text_primary"
                android:textColorHint="@color/sol_text_secondary"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:padding="16dp"
                android:src="@drawable/ic_eye"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/password_show"
                app:tint="@color/color_icon_inactive" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/loginOptionsRow"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/rememberAction"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_checkbox_checked"
                    android:padding="3dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/remember_me"
                        android:src="@drawable/ic_check" />
                </FrameLayout>

                <CheckBox
                    android:id="@+id/chkRememberMe"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:button="@null"
                    android:checked="true"
                    android:visibility="invisible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center_vertical"
                    android:text="@string/remember_me"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center"
                android:text="@string/forgot_password"
                android:textColor="@color/sol_gold_dark"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_gold_button"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:drawablePadding="56dp"
            android:text="@string/sign_in"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txtNoAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/no_account"
            android:textColor="@color/sol_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtSignUp"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrowright"
            android:drawablePadding="8dp"
            android:drawableTint="@color/color_icon_primary"
            android:text="@string/sign_up"
            android:textColor="@color/sol_gold_dark"
            android:textSize="16sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
