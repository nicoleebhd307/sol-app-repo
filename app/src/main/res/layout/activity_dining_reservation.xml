<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    tools:context=".activities.DiningReservationActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnDiningBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_gold"
                    android:contentDescription="@string/signup_back">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_restaurant"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.12"
                    android:text="@string/dining_kicker"
                    android:textColor="@color/sol_gold_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/sol_gold_dark" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/cormorant_garamond"
                android:text="@string/dining_title"
                android:textColor="@color/sol_text_primary"
                android:textSize="38sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="@string/dining_subtitle"
                android:textColor="@color/sol_text_secondary"
                android:textSize="14sp" />

            <!-- Booking card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_dashboard_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="86dp"
                    android:layout_height="66dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imgDiningRoom"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/detail_room_photo"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_login" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtDiningRoomType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.03"
                        android:singleLine="true"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="DELUXE SUITE" />

                    <TextView
                        android:id="@+id/txtDiningRoomNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp"
                        tools:text="Room 302" />

                    <TextView
                        android:id="@+id/txtDiningBookingCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="12sp"
                        tools:text="Booking ID: BK-2026-1045" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_status_success"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/account_status_active"
                        android:textColor="@color/color_icon_success"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_roomservice"
                        app:tint="@color/sol_gold_dark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Date + time slot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/rowDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:text="@string/dining_date"
                                android:textColor="@color/sol_text_secondary"
                                android:textSize="10sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtDiningDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/plus_jakarta_sans"
                                    android:textColor="@color/sol_text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="14 Oct 2026" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_chevrondown" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/sol_border" />

                    <LinearLayout
                        android:id="@+id/rowTimeSlot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_clock" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:text="@string/dining_time_slot"
                                android:textColor="@color/sol_text_secondary"
                                android:textSize="10sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtTimeSlot"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/plus_jakarta_sans"
                                    android:textColor="@color/sol_text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="7:00 PM" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_chevrondown" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/inter"
                    android:text="@string/dining_operating"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Restaurant layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/dining_layout"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_amenity_item"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <GridLayout
                        android:id="@+id/gridSmallTables"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:columnCount="3" />

                    <LinearLayout
                        android:id="@+id/listLargeTables"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_table_rect_available" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="18dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/dining_legend_available"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_table_rect_selected" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="18dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/dining_legend_selected"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_table_rect_booked" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/dining_legend_booked"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Your selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:text="@string/dining_your_selection"
                    android:textColor="@color/sol_gold_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        style="@style/DiningSelCell">

                        <TextView
                            style="@style/DiningSelLabel"
                            android:text="@string/dining_table" />

                        <TextView
                            android:id="@+id/txtSelTable"
                            style="@style/DiningSelValue"
                            tools:text="B4" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/DiningSelCell">

                        <TextView
                            style="@style/DiningSelLabel"
                            android:text="@string/dining_capacity" />

                        <TextView
                            android:id="@+id/txtSelCapacity"
                            style="@style/DiningSelValue"
                            tools:text="4 Guests" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/DiningSelCell">

                        <TextView
                            style="@style/DiningSelLabel"
                            android:text="@string/dining_date_field" />

                        <TextView
                            android:id="@+id/txtSelDate"
                            style="@style/DiningSelValue"
                            tools:text="14 Oct 2026" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        style="@style/DiningSelCell"
                        android:layout_weight="2">

                        <TextView
                            style="@style/DiningSelLabel"
                            android:text="@string/dining_venue" />

                        <TextView
                            android:id="@+id/txtSelVenue"
                            style="@style/DiningSelValue"
                            android:text="@string/dining_venue_name" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/DiningSelCell"
                        android:layout_weight="1">

                        <TextView
                            style="@style/DiningSelLabel"
                            android:text="@string/dining_time" />

                        <TextView
                            android:id="@+id/txtSelTime"
                            style="@style/DiningSelValue"
                            tools:text="7:00 PM" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_clock" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/dining_hold"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnConfirmTable"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_gold_button"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:text="@string/dining_confirm"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
