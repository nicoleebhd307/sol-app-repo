<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="10dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_status_completed" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/cormorant_garamond"
            android:text="@string/filter_title"
            android:textColor="@color/sol_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCloseFilter"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/filter_close"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/sol_text_primary"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter"
        android:letterSpacing="0.1"
        android:text="@string/filter_room_type"
        android:textColor="@color/sol_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chipAllRooms"
            style="@style/FilterChip"
            android:text="@string/filter_all_rooms" />

        <TextView
            android:id="@+id/chipSuites"
            style="@style/FilterChip"
            android:text="@string/filter_suites" />

        <TextView
            android:id="@+id/chipVillas"
            style="@style/FilterChip"
            android:text="@string/filter_villas" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter"
        android:letterSpacing="0.1"
        android:text="@string/filter_price_range"
        android:textColor="@color/sol_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtMinPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="$300" />

        <TextView
            android:id="@+id/txtMaxPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="$1,500" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekMinPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/filter_min_price"
        android:progressTint="@color/sol_gold"
        android:thumbTint="@color/sol_gold" />

    <SeekBar
        android:id="@+id/seekMaxPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:contentDescription="@string/filter_max_price"
        android:progressTint="@color/sol_gold"
        android:thumbTint="@color/sol_gold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter"
        android:letterSpacing="0.1"
        android:text="@string/filter_views"
        android:textColor="@color/sol_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chipViewOcean"
            style="@style/FilterChip"
            android:text="@string/filter_view_ocean" />

        <TextView
            android:id="@+id/chipViewGarden"
            style="@style/FilterChip"
            android:text="@string/filter_view_garden" />

        <TextView
            android:id="@+id/chipViewPool"
            style="@style/FilterChip"
            android:text="@string/filter_view_pool" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter"
        android:letterSpacing="0.1"
        android:text="@string/filter_guest_capacity"
        android:textColor="@color/sol_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chipGuests2"
            style="@style/FilterChip"
            android:text="@string/filter_guests_2" />

        <TextView
            android:id="@+id/chipGuests3"
            style="@style/FilterChip"
            android:text="@string/filter_guests_3" />

        <TextView
            android:id="@+id/chipGuests4"
            style="@style/FilterChip"
            android:text="@string/filter_guests_4" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_gold_button"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:text="@string/filter_apply"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
