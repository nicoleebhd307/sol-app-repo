<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sol_background"
    android:fillViewport="true"
    tools:context=".activities.BookingCheckoutActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/btnCheckoutBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/detail_back">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrowleft" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/cormorant_garamond"
                android:text="@string/checkout_title"
                android:textColor="@color/sol_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_dashboard_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <androidx.cardview.widget.CardView
                android:layout_width="130dp"
                android:layout_height="110dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgCheckoutRoom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/detail_room_photo"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/bg_login" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtCheckoutRoomName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    tools:text="Scenic Ocean View" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_calendar" />

                    <TextView
                        android:id="@+id/txtCheckoutDates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp"
                        tools:text="Oct 12 - Oct 18" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtCheckoutGuestsNights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="12sp"
                    tools:text="2 Adults  |  6 Nights" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtCheckoutPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="$650" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/booking_price_per_night"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_dashboard_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_phone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/checkout_phone_section"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="2"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/checkout_country"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/inputCountryCode"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:importantForAutofill="no"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="+84"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="14sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/checkout_mobile_number"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/inputMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:hint="@string/checkout_mobile_number"
                        android:importantForAutofill="no"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/sol_text_primary"
                        android:textColorHint="@color/sol_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_dashboard_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_profile" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/checkout_guest_section"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/checkout_full_name"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/inputFullName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:hint="@string/checkout_full_name"
                        android:importantForAutofill="no"
                        android:inputType="textPersonName|textCapWords"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/sol_text_primary"
                        android:textColorHint="@color/sol_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/checkout_email"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/inputEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:hint="@string/checkout_email"
                        android:importantForAutofill="no"
                        android:inputType="textEmailAddress"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/sol_text_primary"
                        android:textColorHint="@color/sol_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.1"
                android:text="@string/checkout_id_passport"
                android:textColor="@color/sol_text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/inputIdPassport"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:fontFamily="@font/plus_jakarta_sans"
                android:hint="@string/checkout_id_passport"
                android:importantForAutofill="no"
                android:inputType="textCapCharacters"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/sol_text_primary"
                android:textColorHint="@color/sol_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_dashboard_card"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imgSummaryThumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/bg_login" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtSummaryLine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.05"
                    android:singleLine="true"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="SCENIC OCEAN VIEW • OCT 12 - OCT 18" />

                <TextView
                    android:id="@+id/btnEditSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:padding="4dp"
                    android:text="@string/checkout_edit"
                    android:textColor="@color/sol_gold_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/sol_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtRoomTotalLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp"
                        tools:text="Room Total (6 Nights)" />

                    <TextView
                        android:id="@+id/txtRoomTotalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$3,900" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/checkout_services"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtServicesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/checkout_taxes_fees"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtTaxesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$390" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkAcceptPolicies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:buttonTint="@color/sol_gold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/checkout_accept_policies"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:letterSpacing="0.1"
                            android:text="@string/checkout_due_now"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtDueNow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/cormorant_garamond"
                            android:textColor="@color/sol_gold_dark"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="$1,250.00" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnConfirmBooking"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_gold_button"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:text="@string/checkout_confirm_booking"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
