<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_dashboard_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtRsOrderCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:singleLine="true"
            android:textColor="@color/sol_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Order RS-2026-1045" />

        <TextView
            android:id="@+id/txtRsOrderMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_secondary"
            android:textSize="12sp"
            tools:text="3 items · $54.70" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtRsOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:background="@drawable/bg_status_warning"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="@color/color_icon_warning"
            android:textSize="9sp"
            android:textStyle="bold"
            tools:text="PREPARING" />

        <TextView
            android:id="@+id/btnRsOrderTrack"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_outline_button"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/rs_track_order"
            android:textColor="@color/sol_gold_dark"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
