<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_spa_session_available"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_horizontal"
    android:minHeight="62dp"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/badgeSelected"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="end"
        android:contentDescription="@null"
        android:src="@drawable/ic_check"
        android:visibility="gone"
        app:tint="@color/sol_gold_dark"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/txtSessionTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:gravity="center"
        android:textColor="@color/sol_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="08:00 – 08:40" />

    <TextView
        android:id="@+id/txtSessionLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:gravity="center"
        android:textColor="@color/sol_text_secondary"
        android:textSize="11sp"
        tools:text="6 left" />
</LinearLayout>
