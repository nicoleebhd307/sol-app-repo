<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    tools:context=".activities.SpaServiceActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnSpaBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_gold"
                    android:contentDescription="@string/signup_back">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrowleft"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.12"
                    android:text="@string/spa_kicker"
                    android:textColor="@color/sol_gold_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/sol_gold_dark" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/cormorant_garamond"
                android:text="@string/spa_title"
                android:textColor="@color/sol_text_primary"
                android:textSize="38sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="@string/spa_subtitle"
                android:textColor="@color/sol_text_secondary"
                android:textSize="14sp" />

            <!-- Booking summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtSpaRoomType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/cormorant_garamond"
                    android:singleLine="true"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="DELUXE SUITE" />

                <TextView
                    android:id="@+id/txtSpaBookingCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp"
                    tools:text="BK-2026-1045" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        style="@style/SpaFactCell">

                        <ImageView
                            style="@style/SpaFactIcon"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            style="@style/SpaFactLabel"
                            android:text="@string/home_check_in" />

                        <TextView
                            android:id="@+id/txtSpaCheckIn"
                            style="@style/SpaFactValue"
                            tools:text="14 Oct 2026" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SpaFactCell">

                        <ImageView
                            style="@style/SpaFactIcon"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            style="@style/SpaFactLabel"
                            android:text="@string/home_check_out" />

                        <TextView
                            android:id="@+id/txtSpaCheckOut"
                            style="@style/SpaFactValue"
                            tools:text="15 Oct 2026" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SpaFactCell">

                        <ImageView
                            style="@style/SpaFactIcon"
                            android:src="@drawable/ic_profile" />

                        <TextView
                            style="@style/SpaFactLabel"
                            android:text="@string/home_guests" />

                        <TextView
                            android:id="@+id/txtSpaGuests"
                            style="@style/SpaFactValue"
                            tools:text="2 Guests" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SpaFactCell">

                        <ImageView
                            style="@style/SpaFactIcon"
                            android:src="@drawable/ic_home" />

                        <TextView
                            style="@style/SpaFactLabel"
                            android:text="@string/home_room" />

                        <TextView
                            android:id="@+id/txtSpaRoom"
                            style="@style/SpaFactValue"
                            tools:text="501" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Spa session card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_booking_selected"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_soft">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_wellness"
                            app:tint="@color/sol_gold_dark" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cormorant_garamond"
                            android:text="@string/spa_session_card_title"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSpaSessionDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="13sp"
                            tools:text="40-minute spa session — pay per slot." />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_circle_gold">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check"
                            app:tint="@color/white" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        style="@style/SpaInfoChip">

                        <ImageView
                            style="@style/SpaInfoChipIcon"
                            android:src="@drawable/ic_card" />

                        <TextView
                            android:id="@+id/txtSpaPrice"
                            style="@style/SpaInfoChipText"
                            tools:text="350.000 ₫\n/ guest / session" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SpaInfoChip">

                        <ImageView
                            style="@style/SpaInfoChipIcon"
                            android:src="@drawable/ic_profile" />

                        <TextView
                            android:id="@+id/txtSpaSpecialists"
                            style="@style/SpaInfoChipText"
                            tools:text="10\nspa specialists" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SpaInfoChip">

                        <ImageView
                            style="@style/SpaInfoChipIcon"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            style="@style/SpaInfoChipText"
                            android:text="@string/spa_sessions_multiple" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Operating schedule -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/sol_gold_dark" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cormorant_garamond"
                            android:text="@string/spa_schedule_title"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/spa_operating_hours"
                            android:textColor="@color/sol_gold_dark"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/sol_gold_dark" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter"
                        android:text="@string/spa_morning_team"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/spa_morning_hours"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/sol_gold_dark" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter"
                        android:text="@string/spa_afternoon_team"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/spa_afternoon_hours"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Info note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_amenity_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info"
                    app:tint="@color/sol_gold_dark" />

                <TextView
                    android:id="@+id/txtSpaInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="12sp"
                    tools:text="@string/spa_info_paid" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSpaContinue"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_gold_button"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:text="@string/spa_continue"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
