<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sol_background"
    tools:context=".activities.RoomDetailActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/panelReserve"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="18dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/imgDetailRoom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/detail_room_photo"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/bg_login" />

                <FrameLayout
                    android:id="@+id/btnDetailBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle_white"
                    android:contentDescription="@string/detail_back">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrowleft" />
                </FrameLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/txtDetailName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/cormorant_garamond"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/sol_text_primary"
                android:textSize="34sp"
                android:textStyle="bold"
                tools:text="Scenic Ocean View" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_status_upcoming"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_wave" />

                    <TextView
                        android:id="@+id/txtDetailViewBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Ocean View" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badgeBestSeller"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_status_warning"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/badge_best_seller"
                        android:textColor="@color/color_icon_warning"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/txtDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textColor="@color/sol_gold_dark"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    tools:text="$650" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/booking_price_per_night"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_profile" />

                <TextView
                    android:id="@+id/txtDetailAdults"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp"
                    tools:text="2 Adults" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@color/sol_border" />

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_area" />

                <TextView
                    android:id="@+id/txtDetailSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp"
                    tools:text="550 sqft" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@color/sol_border" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bed" />

                <TextView
                    android:id="@+id/txtDetailBed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp"
                    tools:text="King Bed" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/sol_text_secondary"
                android:textSize="14sp"
                tools:text="Wake up to a panoramic ocean view with elegant interiors, private balcony, and curated resort amenities." />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="20dp"
                android:background="@color/sol_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/cormorant_garamond"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/detail_amenities"
                android:textColor="@color/sol_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/gridAmenities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:id="@+id/btnPickCheckIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_calendar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/detail_check_in"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/txtDetailCheckIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Oct 12" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevrondown" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:id="@+id/btnPickCheckOut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_calendar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/detail_check_out"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/txtDetailCheckOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Oct 18" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevrondown" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:id="@+id/btnPickGuests"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_profile" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.1"
                        android:text="@string/detail_guests"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/txtDetailGuests"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="2 Adults" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevrondown" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/panelReserve"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/sol_background"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btnReserveNow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_gold_button"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:text="@string/detail_reserve_now"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
