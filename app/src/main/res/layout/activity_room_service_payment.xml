<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sol_background"
    tools:context=".activities.RoomServicePaymentActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnPaymentBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="@string/detail_back">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrowleft" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/rs_payment_title"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <include
                android:id="@+id/cardPaymentBooking"
                layout="@layout/view_rs_booking_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:text="@string/rs_payment_method"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Collapsed selector: tap to expand the list of payment methods. -->
                <LinearLayout
                    android:id="@+id/paymentMethodSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/imgSelectedMethod"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_card"
                        android:tint="@color/sol_gold_dark" />

                    <TextView
                        android:id="@+id/txtSelectedMethod"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Bank Card" />

                    <ImageView
                        android:id="@+id/imgMethodChevron"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevrondown"
                        android:tint="@color/sol_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/paymentMethodOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                <LinearLayout
                    android:id="@+id/rowMethodBankCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_card" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_pay_bank_card"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_pay_bank_card_hint"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/radioBankCard"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_circle_ring">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check"
                            android:tint="@color/white"
                            android:visibility="gone"
                            tools:ignore="UseAppTint" />
                    </FrameLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:id="@+id/rowMethodEwallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_wallet" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_pay_ewallet"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_pay_ewallet_hint"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/radioEwallet"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_circle_ring">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check"
                            android:tint="@color/white"
                            android:visibility="gone"
                            tools:ignore="UseAppTint" />
                    </FrameLayout>
                </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCardDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:text="@string/rs_cardholder_name"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/inputCardholder"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:hint="@string/rs_cardholder_name"
                    android:importantForAutofill="no"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/sol_text_primary"
                    android:textColorHint="@color/sol_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:text="@string/rs_card_number"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/inputCardNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:hint="@string/rs_card_number_hint"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:maxLength="19"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/sol_text_primary"
                    android:textColorHint="@color/sol_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:letterSpacing="0.08"
                            android:text="@string/rs_expiry_date"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/inputExpiry"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:hint="@string/rs_expiry_hint"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            android:maxLength="7"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@color/sol_text_primary"
                            android:textColorHint="@color/sol_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:letterSpacing="0.08"
                            android:text="@string/rs_cvv"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/inputCvv"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:hint="@string/rs_cvv_hint"
                            android:importantForAutofill="no"
                            android:inputType="numberPassword"
                            android:maxLength="4"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@color/sol_text_primary"
                            android:textColorHint="@color/sol_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:text="@string/rs_order_summary"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/rs_subtotal"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPaySubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$47.00" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/rs_service_charge"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPayServiceCharge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$4.70" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/rs_total"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPayTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="$54.70" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center"
                android:text="@string/rs_secure_payment"
                android:textColor="@color/sol_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnPayNow"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_gold_button"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="@string/rs_pay_now"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
