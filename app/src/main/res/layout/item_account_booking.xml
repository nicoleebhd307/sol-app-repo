<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_dashboard_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:layout_width="96dp"
        android:layout_height="74dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgAccountBookingRoom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/account_my_bookings"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_room_thumb" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtSessionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_status_gold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingStart="8dp"
            android:paddingTop="2dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp"
            android:text="@string/account_session_viewing"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/txtAccountBookingRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:singleLine="true"
            android:textColor="@color/sol_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Beach Villa" />

        <TextView
            android:id="@+id/txtAccountBookingDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:singleLine="true"
            android:textColor="@color/sol_text_secondary"
            android:textSize="12sp"
            tools:text="Jul 04, 2026 - Jul 08, 2026" />

        <TextView
            android:id="@+id/txtAccountBookingGuests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_secondary"
            android:textSize="12sp"
            tools:text="4 Guests" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAccountBookingStatus"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:minWidth="92dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="CURRENT" />

        <TextView
            android:id="@+id/btnViewBookingDetails"
            android:layout_width="104dp"
            android:layout_height="34dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:text="@string/account_view_details"
            android:textColor="@color/sol_gold_dark"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
