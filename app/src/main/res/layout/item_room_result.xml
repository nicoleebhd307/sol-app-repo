<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_dashboard_card"
    android:orientation="vertical"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgRoom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/detail_room_photo"
            android:scaleType="centerCrop"
            tools:src="@drawable/bg_login" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_badge_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_wave" />

            <TextView
                android:id="@+id/txtViewBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.05"
                android:textColor="@color/sol_text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="OCEAN VIEW" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtRoomName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/cormorant_garamond"
        android:textColor="@color/sol_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="Scenic Ocean View" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_profile" />

        <TextView
            android:id="@+id/txtRoomAdults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_secondary"
            android:textSize="13sp"
            tools:text="2 Adults" />

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/sol_border" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_area" />

        <TextView
            android:id="@+id/txtRoomSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/sol_text_secondary"
            android:textSize="13sp"
            tools:text="550 sqft" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="@color/sol_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtRoomPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond"
            android:textColor="@color/sol_gold_dark"
            android:textSize="27sp"
            android:textStyle="bold"
            tools:text="$650" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/booking_price_per_night"
            android:textColor="@color/sol_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnBookRoom"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_gold_button"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:minWidth="104dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/booking_book"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
