<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sol_background"
    tools:context=".activities.RoomServiceActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/cardCurrentOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_status_success"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="@string/rs_current_order"
                        android:textColor="@color/color_icon_success"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/txtCurrentOrderStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_status_warning"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/color_icon_warning"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:text="PREPARING" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_soft"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_roomservice" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cormorant_garamond"
                            android:text="@string/rs_title"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtCurrentOrderCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/sol_gold_dark"
                            android:textSize="12sp"
                            tools:text="Order ID: RS-2026-1045" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowOrderProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_clock" />

                    <TextView
                        android:id="@+id/txtCurrentOrderEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp"
                        tools:text="ETA 25–30 min" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bag" />

                    <TextView
                        android:id="@+id/txtCurrentOrderItems"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp"
                        tools:text="3 items" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_wallet" />

                    <TextView
                        android:id="@+id/txtCurrentOrderTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="11sp"
                        tools:text="$54.70" />

                    <TextView
                        android:id="@+id/btnTrackOrder"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_outline_button"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/rs_track_order"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardStayInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_dashboard_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="86dp"
                    android:layout_height="66dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imgStayRoom"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/detail_room_photo"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_login" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtStayRoomType"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:letterSpacing="0.05"
                            android:singleLine="true"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="BEACH VILLA" />

                        <TextView
                            android:id="@+id/txtStayStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="22dp"
                            android:background="@drawable/bg_status_upcoming"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:gravity="center"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textColor="@color/sol_gold_dark"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            tools:text="CONFIRMED" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtStayRoomNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp"
                        tools:text="Room V301" />

                    <TextView
                        android:id="@+id/txtStayBookingCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="12sp"
                        tools:text="Booking ID: BK-2026-1046" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_roomservice" />

                    <TextView
                        android:id="@+id/txtDeliverTo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="10sp"
                        tools:text="Deliver to\nRoom V301" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_search"
                    android:tint="@color/sol_text_secondary"
                    tools:ignore="UseAppTint" />

                <EditText
                    android:id="@+id/inputMenuSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:hint="@string/rs_search_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:textColor="@color/sol_text_primary"
                    android:textColorHint="@color/sol_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/rowCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/listMenuItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/txtNoMenuItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center"
                android:text="@string/rs_no_items"
                android:textColor="@color/sol_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/cardOrderPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dashboard_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtPreviewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.08"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="YOUR ORDER (2 ITEMS)" />

                <LinearLayout
                    android:id="@+id/listPreviewLines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/rs_subtotal"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPreviewSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/sol_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="$31.00" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/sol_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_clock" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_estimated_delivery"
                            android:textColor="@color/sol_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/rs_eta_value"
                            android:textColor="@color/sol_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/rs_total"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPreviewTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textColor="@color/sol_gold_dark"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="$34.00" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnViewCart"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_gold_button"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="@string/rs_view_cart"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
