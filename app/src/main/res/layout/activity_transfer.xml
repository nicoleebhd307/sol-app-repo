<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    android:fillViewport="true"
    tools:context=".activities.TransferActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/btnTransferBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:contentDescription="@string/signup_back">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrowleft" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:contentDescription="@string/logo_content_description"
                    android:src="@drawable/sol_logo"
                    app:tint="@color/sol_gold_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:letterSpacing="0.2"
                    android:text="@string/brand_name"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/cormorant_garamond"
            android:gravity="center"
            android:text="@string/transfer_title"
            android:textColor="@color/sol_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/transfer_subtitle"
            android:textColor="@color/sol_text_secondary"
            android:textSize="14sp" />

        <!-- Booking summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_dashboard_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtTransferRoomType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/cormorant_garamond"
                android:singleLine="true"
                android:textColor="@color/sol_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="DELUXE SUITE" />

            <TextView
                android:id="@+id/txtTransferBookingCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/sol_text_secondary"
                android:textSize="13sp"
                tools:text="BK-2026-1045" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:background="@color/sol_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout style="@style/SpaFactCell">

                    <ImageView
                        style="@style/SpaFactIcon"
                        android:src="@drawable/ic_calendar" />

                    <TextView
                        style="@style/SpaFactLabel"
                        android:text="@string/home_check_in" />

                    <TextView
                        android:id="@+id/txtTransferCheckIn"
                        style="@style/SpaFactValue"
                        tools:text="14 Oct 2026" />
                </LinearLayout>

                <LinearLayout style="@style/SpaFactCell">

                    <ImageView
                        style="@style/SpaFactIcon"
                        android:src="@drawable/ic_calendar" />

                    <TextView
                        style="@style/SpaFactLabel"
                        android:text="@string/home_check_out" />

                    <TextView
                        android:id="@+id/txtTransferCheckOut"
                        style="@style/SpaFactValue"
                        tools:text="15 Oct 2026" />
                </LinearLayout>

                <LinearLayout style="@style/SpaFactCell">

                    <ImageView
                        style="@style/SpaFactIcon"
                        android:src="@drawable/ic_profile" />

                    <TextView
                        style="@style/SpaFactLabel"
                        android:text="@string/home_guests" />

                    <TextView
                        android:id="@+id/txtTransferGuests"
                        style="@style/SpaFactValue"
                        tools:text="2 Guests" />
                </LinearLayout>

                <LinearLayout style="@style/SpaFactCell">

                    <ImageView
                        style="@style/SpaFactIcon"
                        android:src="@drawable/ic_home" />

                    <TextView
                        style="@style/SpaFactLabel"
                        android:text="@string/home_room" />

                    <TextView
                        android:id="@+id/txtTransferRoom"
                        style="@style/SpaFactValue"
                        tools:text="501" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/cormorant_garamond"
            android:text="@string/transfer_choose_type"
            android:textColor="@color/sol_gold_dark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:text="@string/transfer_choose_type_sub"
            android:textColor="@color/sol_text_secondary"
            android:textSize="13sp" />

        <!-- Pickup option -->
        <LinearLayout
            android:id="@+id/optionPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_dashboard_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_soft">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_transfer"
                    app:tint="@color/sol_gold_dark" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/transfer_pickup"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/transfer_pickup_route"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/radioPickup"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_circle_ring">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check"
                    android:tint="@color/white"
                    android:visibility="gone"
                    tools:ignore="UseAppTint" />
            </FrameLayout>
        </LinearLayout>

        <!-- Drop-off option -->
        <LinearLayout
            android:id="@+id/optionDropoff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dashboard_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_soft">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_transfer"
                    app:tint="@color/sol_gold_dark" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:text="@string/transfer_dropoff"
                    android:textColor="@color/sol_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/transfer_dropoff_route"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/radioDropoff"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_circle_ring">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check"
                    android:tint="@color/white"
                    android:visibility="gone"
                    tools:ignore="UseAppTint" />
            </FrameLayout>
        </LinearLayout>

        <!-- Info note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_amenity_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_info"
                app:tint="@color/sol_gold_dark" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter"
                android:text="@string/transfer_info_intro"
                android:textColor="@color/sol_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Schedule section: revealed after a transfer type is chosen -->
        <LinearLayout
            android:id="@+id/sectionSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/cormorant_garamond"
                android:text="@string/transfer_preferred_date"
                android:textColor="@color/sol_gold_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chipDateContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/cormorant_garamond"
                android:text="@string/transfer_time_title"
                android:textColor="@color/sol_gold_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="@string/transfer_time_sub"
                android:textColor="@color/sol_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_dashboard_card"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <TimePicker
                    android:id="@+id/timePickerTransfer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:timePickerMode="spinner" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/sol_text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/transfer_time_format_note"
                        android:textColor="@color/sol_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_amenity_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info"
                    app:tint="@color/sol_gold_dark" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:text="@string/transfer_time_info"
                    android:textColor="@color/sol_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnTransferContinue"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_gold_button"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:text="@string/transfer_continue"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
